# KidsAI Studio - 环境变量模板
# 复制为 .env 并填入真实 key；.env 已被 .gitignore，不会进 git

# ===== LLM Provider =====
# 优先级：MINIMAX > DEEPSEEK > OPENAI > DASHSCOPE > mock

# MiniMax（默认）
# 申请：https://platform.minimaxi.com/user-center/basic-information/Interface-key
MINIMAX_API_KEY=
# Key 池：逗号分隔多个 key，池内 401/429 自动失败转移到下一个 key（Token Plan task #31）
# 留空时回退到单个 MINIMAX_API_KEY
MINIMAX_API_KEYS=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3

# DeepSeek（OpenAI 兼容备用）
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com

# Qwen / 通义千问
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-plus

# ===== Video Provider (image_to_video) =====
# 火山方舟 Seedance（火山引擎 ARK）— async task 轮询
# 申请 / 子账号：https://console.volcengine.com/ark
# 同一 BASE_URL 下通过 SEEDANCE_MODEL 切换 2.0 / 2.0-fast / 2.0-mini
SEEDANCE_API_KEY=
SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 模型可填 Model ID 或 Endpoint ID（ep-...）。默认走 2.0-mini（最省，仅 480P/720P）
# 档位：2.0-mini（默认）/ 2.0-fast / 2.0（支持 1080P/4K）
SEEDANCE_MODEL=doubao-seedance-2-0-mini-260128
# 没填 SEEDANCE_API_KEY 就走 Mock（w3schools 示例 mp4）
