# KidsAI Studio - 环境变量模板
# 复制为 .env 并填入真实 key；.env 已被 .gitignore，不会进 git

# ===== LLM Provider =====
# 优先级：MINIMAX > DEEPSEEK > OPENAI > DASHSCOPE > mock

# MiniMax（默认）
# 申请：https://platform.minimaxi.com/user-center/basic-information/Interface-key
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3

# DeepSeek（OpenAI 兼容备用）
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com

# Qwen / 通义千问
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-plus
