# KidsAI Server 生产环境变量 (W4.5 B3)
#
# 部署: cp 此文件到 /etc/kidsai-server/.env, chmod 600, 填真实值
#
# 用 openssl 生成密钥:
#   openssl rand -hex 32      # JWT_SECRET
#   openssl rand -hex 16      # ADMIN_TOKEN (也可手选易记的)

# ============ 必填 ============

# JWT HS256 签名密钥 (32+ 字节)
JWT_SECRET=

# 管理员 token (admin grant/revoke 用 X-Admin-Token header)
ADMIN_TOKEN=

# 真实 API key — **必须** 在 provider 控制台轮换后填入
# (W4.5 A1: 旧 key 在 docs/00-账号信息/code.md 已暴露, 不能复用)
LLM_API_KEY=
SEEDANCE_API_KEY=

# ============ 调优 (可选) ============

# JWT 有效期 (秒), 默认 86400 = 24h
JWT_TTL_SECONDS=86400

# 学币计费
STARTING_BALANCE=100
DAILY_QUOTA=30
COST_PER_LLM_TOKEN=0.001
COST_VIDEO_DRAFT=9
COST_VIDEO_FINAL=19
SINGLE_TX_CAP=20

# 监听端口 (systemd unit 默认 8080)
PORT=8080

# 数据库路径 (相对 APP_DIR 或绝对路径)
DATABASE_PATH=./data/kidsai.db