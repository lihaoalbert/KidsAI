# KidsAI Server 环境变量模板 (W4.5 B1)
# 真实部署由 systemd EnvironmentFile 注入 (root 700)

# JWT 签名密钥 — 32+ 字节随机, 用 `openssl rand -hex 32` 生成
JWT_SECRET=change-me-to-32-byte-random-hex-secret

# JWT 默认有效期 (秒), 默认 86400 = 24h
JWT_TTL_SECONDS=86400

# 管理员 token (header: X-Admin-Token), 部署时由 lihao 记下
ADMIN_TOKEN=change-me-to-admin-token

# 学币计费常量
STARTING_BALANCE=100
DAILY_QUOTA=30
COST_PER_LLM_TOKEN=0.001
COST_VIDEO_DRAFT=9
COST_VIDEO_FINAL=19
SINGLE_TX_CAP=20

# SQLite 数据库路径 (相对 /opt/kidsai-server 或绝对路径)
DATABASE_PATH=./data/kidsai.db

# API key 池 — 桌面拿到 license 后用这些 key 直连 provider
# B1 阶段先用占位符; 实际部署 (B3) 由 lihao 从 provider 控制台轮换后注入
LLM_API_KEY=sk-placeholder-llm-key-rotate-before-seed
SEEDANCE_API_KEY=placeholder-seedance-key-rotate-before-seed

# 监听端口
PORT=8080